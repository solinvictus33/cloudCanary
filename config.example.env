# CloudCanary configuration — copy to config.env (gitignored) or set in your scheduler.
# NEVER commit a real webhook URL.

SLACK_WEBHOOK_URL="https://hooks.slack.com/services/REPLACE/ME/EXAMPLE"
STATE_DIR="${HOME}/.cloudcanary/state"

# Optional scoping
#PROJECT_INCLUDE_FILTER="parent.id=123456789012"
#PROJECT_EXCLUDE_REGEX="^(sandbox-|scratch-)"

WATCH_SA_KEYS="true"
WATCH_SA_ROLES="true"
WATCH_AI_WORKLOADS="true"

# AI-endpoint scan regions (space-separated). Vertex endpoints are regional;
# list only the regions you deploy models in to keep the sweep fast.
#AI_ENDPOINT_REGIONS="us-central1 us-east1 europe-west4"
DRY_RUN="false"
